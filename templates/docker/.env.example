# Liferay DXP Docker Environment — base template
# Copia a .env y ajusta los valores para tu proyecto

# ─── Liferay ──────────────────────────────────────────────────────────────────

# Imagen Docker de Liferay DXP. Debe coincidir con liferay.workspace.product en gradle.properties.
LIFERAY_IMAGE=liferay/dxp:2025.q1.0-lts

# JVM settings (ajustar según RAM disponible)
LIFERAY_JVM_OPTS="-Xms2g -Xmx4g -XX:+UseG1GC -XX:MaxGCPauseMillis=200 -Djava.net.preferIPv4Stack=true"

# ─── Puertos (host) ───────────────────────────────────────────────────────────

LIFERAY_HTTP_PORT=8080
LIFERAY_DEBUG_PORT=8000
GOGO_PORT=11311
POSTGRES_PORT=5432
ES_HTTP_PORT=9200

# IP de bind. 127.0.0.1 para uso local. 0.0.0.0 para exponer en red.
# Si se cambia a una IP específica enrutable, liferay-cli la usará como base URL.
BIND_IP=127.0.0.1

# ─── PostgreSQL ───────────────────────────────────────────────────────────────

POSTGRES_DB=liferay
POSTGRES_USER=liferay
POSTGRES_PASSWORD=liferay

# ─── Elasticsearch ────────────────────────────────────────────────────────────

ES_JAVA_OPTS="-Xms1g -Xmx1g"

# ─── Volúmenes y datos ────────────────────────────────────────────────────────

# Nombre del proyecto Compose (prefijo para contenedores, redes y volúmenes).
COMPOSE_PROJECT_NAME=liferay

# Nombre del volumen externo para la Document Library.
# Creado automáticamente por task env:start si no existe.
# Por defecto se enlaza a ENV_DATA_ROOT/liferay-doclib
# (ejemplo: docker/data/default/liferay-doclib).
# Los worktrees reutilizan la misma doclib compartida del main.
# Para montar desde NAS o ruta local: task lcp:doclib-mount
DOCLIB_VOLUME_NAME=liferay-doclib

# Raíz de bind mounts locales (postgres-data, liferay-data, elasticsearch-data, etc.)
ENV_DATA_ROOT=./data/default

# Btrfs (opcional — solo Linux con volumen btrfs montado en el host).
# Activar para snapshots de worktrees. El tooling NO escribe estas vars automáticamente.
# IMPORTANTE: sin USE_BTRFS_SNAPSHOTS definido el tooling no activa Btrfs,
# aunque /mnt/docker-btrfs exista en el host.
#BTRFS_ROOT=/mnt/docker-btrfs
#USE_BTRFS_SNAPSHOTS=auto
#ENV_DATA_ROOT=/mnt/docker-btrfs/main

# NAS para Document Library (CIFS/SMB). Requiere cifs-utils en el host.
# Activar con: task lcp:doclib-mount (lee estas vars automáticamente).
#DOCLIB_NAS_IP=192.168.1.100
#DOCLIB_NAS_SHARE=liferay/doclib
#DOCLIB_NAS_USER=usuario
#DOCLIB_NAS_PASS=contraseña
#DOCLIB_NAS_PORT=445

# ─── liferay-cli ──────────────────────────────────────────────────────────────

# URL base del portal local. Se auto-calcula desde BIND_IP + LIFERAY_HTTP_PORT
# si BIND_IP es una IP enrutable. Descomentar solo si necesitas forzar un valor.
#LIFERAY_CLI_URL=http://127.0.0.1:8080

# Nombre de cookie de sesión Tomcat. Si se deja vacío, el contenedor usa
# JSESSIONID_<puerto> para evitar colisiones entre main y worktrees activos
# a la vez sobre el mismo host.
#LIFERAY_SESSION_COOKIE_NAME=

# Credenciales OAuth2 generadas por el módulo liferay-cli-bootstrap.
# Obtener tras primer arranque con: task osgi:liferaycli-creds
LIFERAY_CLI_OAUTH2_COMPANY_WEB_ID=liferay.local
LIFERAY_CLI_OAUTH2_ADMIN_EMAIL=admin@liferay.local
#LIFERAY_CLI_OAUTH2_CLIENT_ID=
#LIFERAY_CLI_OAUTH2_CLIENT_SECRET=

# ─── Liferay Cloud Platform ───────────────────────────────────────────────────
# Necesario para: task db:sync, task lcp:doclib-download, task lcp:doclib-mount

LCP_PROJECT=my-lcp-project
LCP_ENVIRONMENT=prd

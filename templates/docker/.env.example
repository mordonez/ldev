# Liferay DXP Docker environment - base template
# Copy to .env and adjust the values for your project.
# SECURITY: keep docker/.env local only. Never commit real secrets.

# --- Liferay -----------------------------------------------------------------

# Default Liferay DXP Docker image.
# Keep this aligned with the documented baseline and with liferay.workspace.product in gradle.properties.
LIFERAY_IMAGE=liferay/dxp:2026.q1.0-lts

# JVM settings (adjust for the RAM available on your host)
LIFERAY_JVM_OPTS="-Xms2g -Xmx4g -XX:+UseG1GC -XX:MaxGCPauseMillis=200 -Djava.net.preferIPv4Stack=true"

# --- Host ports --------------------------------------------------------------

LIFERAY_HTTP_PORT=8080
LIFERAY_DEBUG_PORT=8000
GOGO_PORT=11311
POSTGRES_PORT=5432
ES_HTTP_PORT=9200

# IP de bind. 127.0.0.1 para uso local. 0.0.0.0 para exponer en red.
# Si se cambia a una IP específica enrutable, liferay-cli la usará como base URL.
BIND_IP=127.0.0.1

# --- PostgreSQL --------------------------------------------------------------

POSTGRES_DB=liferay
POSTGRES_USER=liferay
POSTGRES_PASSWORD=liferay

# --- Elasticsearch -----------------------------------------------------------

ES_JAVA_OPTS="-Xms1g -Xmx1g"

# --- Volumes and data --------------------------------------------------------

# Docker Compose files to load. Set by ldev project init --services.
# Uncomment and adjust if you need to add or remove services manually.
# Full stack example: docker-compose.yml:docker-compose.postgres.yml:docker-compose.elasticsearch.yml
#COMPOSE_FILE=docker-compose.yml

# Compose project name (prefix for containers, networks, and volumes).
COMPOSE_PROJECT_NAME=liferay

# External volume name for the Document Library.
# Created automatically by env start if it does not exist.
# By default it points to ENV_DATA_ROOT/liferay-doclib
# (example: docker/data/default/liferay-doclib).
# Worktrees reuse the same shared main doclib.
DOCLIB_VOLUME_NAME=liferay-doclib

# Root directory for local bind mounts (postgres-data, liferay-data, elasticsearch-data, etc.)
ENV_DATA_ROOT=./data/default

# Btrfs (optional - Linux only, with a btrfs volume mounted on the host).
# Enable only for worktree snapshots. The tooling does not write these vars automatically.
# Important: without USE_BTRFS_SNAPSHOTS set, the tooling does not activate Btrfs,
# even if /mnt/docker-btrfs exists on the host.
#BTRFS_ROOT=/mnt/docker-btrfs
#USE_BTRFS_SNAPSHOTS=auto
#ENV_DATA_ROOT=/mnt/docker-btrfs/main

# NAS mount for the Document Library (CIFS/SMB). Requires cifs-utils on the host.
#DOCLIB_NAS_IP=192.168.1.100
#DOCLIB_NAS_SHARE=liferay/doclib
#DOCLIB_NAS_USER=user
#DOCLIB_NAS_PASS=password
#DOCLIB_NAS_PORT=445

# --- ldev --------------------------------------------------------------------

# Base URL of the local portal. It is derived from BIND_IP + LIFERAY_HTTP_PORT
# when BIND_IP is a routable address. Uncomment only if you need to force a value.
#LIFERAY_CLI_URL=http://127.0.0.1:8080

# Tomcat session cookie name. If left empty, the container uses
# JSESSIONID_<port> to avoid collisions between main and worktrees active
# on the same host.
#LIFERAY_SESSION_COOKIE_NAME=

# OAuth2 credentials used by authenticated ldev commands.
# Create or refresh them from a running portal with: ldev oauth install --write-env
# Prefer injecting these from your shell, CI, or secret manager.
#LIFERAY_CLI_OAUTH2_CLIENT_ID=
#LIFERAY_CLI_OAUTH2_CLIENT_SECRET=

# --- Liferay Cloud Platform --------------------------------------------------
# Needed for db sync and related Liferay Cloud workflows

LCP_PROJECT=my-lcp-project
LCP_ENVIRONMENT=prd

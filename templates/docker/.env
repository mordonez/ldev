# Liferay DXP Docker Environment (fresh install)

# Liferay image
LIFERAY_IMAGE=liferay/dxp:2025.q1.17-lts

BIND_IP=100.115.222.80

# Liferay ports (host)
LIFERAY_HTTP_PORT=9000
LIFERAY_DEBUG_PORT=9001
LIFERAY_GOGO_PORT=12312

# PostgreSQL
POSTGRES_DB=liferay
POSTGRES_USER=liferay
POSTGRES_PASSWORD=liferay
POSTGRES_PORT=4432
